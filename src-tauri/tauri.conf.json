{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bread of Life",
  "version": "0.3.1",
  "identifier": "com.breadoflife.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Bread of Life",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 620,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "/run/media/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Education",
    "shortDescription": "Your daily Bible homebase",
    "longDescription": "A warm, offline-first homebase for Bible reading, pluggable commentary, journalling, and an answered-prayer log.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
